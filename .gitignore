        "from google.colab import drive\n",
        "import shutil\n",
        "import os\n",
        "\n",
        "# Mount drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# Create thesis backup folder\n",
        "backup_dir = '/content/drive/MyDrive/Thesis-work/CSVs'\n",
        "os.makedirs(backup_dir, exist_ok=True)\n",
        "\n",
        "# List all files to backup\n",
        "files_to_backup = [\n",
        "    'ISIC_2019_Training_GroundTruth.csv',  # Original metadata\n",
        "    'unlabeled_pool_24k.csv',\n",
        "    'expA_train.csv', 'expA_val.csv', 'expA_test.csv',\n",
        "    'expB_train.csv', 'expB_val.csv', 'expB_test.csv',\n",
        "    'expC_train.csv', 'expC_val.csv', 'expC_test.csv',\n",
        "    'dataset_config_summary.txt',\n",
        "    'download_labeled.txt',\n",
        "    'download_unlabeled.txt'\n",
        "]\n",
        "\n",
        "# Copy files\n",
        "for file in files_to_backup:\n",
        "    if os.path.exists(file):\n",
        "        shutil.copy(file, backup_dir)\n",
        "        print(f\"✓ Backed up: {file}\")\n",
        "    else:\n",
        "        print(f\"✗ Missing: {file}\")\n",
        "\n",
        "print(f\"\\nAll files backed up to: {backup_dir}\")"
