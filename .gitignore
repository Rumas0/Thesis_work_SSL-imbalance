          "text": [
            "\n",
            "experiment B (500 images, 1:10) Distribution:\n",
            "label\n",
            "NV     455\n",
            "MEL     45\n",
            "Name: count, dtype: int64\n",
            "Total: 500\n",
            "Imbalance ratio: 1:10.1\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "## Scenario C: Low Resource (100 images, 1:9 ratio)\n",
        "\n",
        "exp_c = create_imbalanced_subset(remaining_labeled_candidates, targets={'MEL': 10, 'NV': 90}, name=\"Experiment C (100 images, 1:9)\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
        "id": "IkQe5V9f8gFt",
        "outputId": "cb16858e-2e64-4de8-8732-4bff508dc167"
      },
      "execution_count": 18,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "Experiment C (100 images, 1:9) Distribution:\n",
            "label\n",
            "NV     90\n",
            "MEL    10\n",
            "Name: count, dtype: int64\n",
            "Total: 100\n",
            "Imbalance ratio: 1:9.0\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Splitting Data into Train/Val/Test (70/15/15) Essentially Stratified Split**"
      ],
      "metadata": {
        "id": "8p7mw7eS9mXP"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "## First >> train(70%) vs temp(30%)\n",
        "def stratified_split(data, name):\n",
        "  train, temp = train_test_split(\n",
        "      data,\n",
        "      test_size=0.30,\n",
        "      random_state=42,\n",
        "      stratify=data['label']\n",
        "  )\n",
        "\n",
        "## Second >> val (15%) VS test (15%)\n",
        "  val, test = train_test_split(\n",
        "      temp,\n",
        "      test_size=0.50,\n",
        "      random_state=42,\n",
        "      stratify=temp['label']\n",
        "  )\n",
        "\n",
        "  print(f'\\n{name} Splits:')\n",
        "  print(f\"Train: {len(train)} ({train['label'].value_counts().to_dict()})\")\n",
        "  print(f\"Val: {len(val)} ({val['label'].value_counts().to_dict()})\")\n",
        "  print(f\"Test: {len(test)} ({test['label'].value_counts().to_dict()})\")\n",
        "\n",
        "  return train, val, test\n",
        "\n",
        "  ## Splitting all experiments\n",
        "train_a, val_a, test_a = stratified_split(exp_a, \"Experiment A\")\n",
        "train_b, val_b, test_b = stratified_split(exp_b, \"Experiment B\")\n",
        "train_c, val_c, test_c = stratified_split(exp_c, \"Experiment C\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "y3ffJBPs-WwF",
        "outputId": "ba44916f-3989-4d6d-998a-806844728113"
      },
      "execution_count": 26,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "Experiment A Splits:\n",
            "Train: 483 ({'NV': 349, 'BKL': 99, 'MEL': 35})\n",
            "Val: 104 ({'NV': 76, 'BKL': 21, 'MEL': 7})\n",
            "Test: 104 ({'NV': 75, 'BKL': 21, 'MEL': 8})\n",
            "\n",
            "Experiment B Splits:\n",
            "Train: 350 ({'NV': 319, 'MEL': 31})\n",
            "Val: 75 ({'NV': 68, 'MEL': 7})\n",
