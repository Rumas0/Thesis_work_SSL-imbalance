            "Train: 70 ({'NV': 63, 'MEL': 7})\n",
            "Val: 15 ({'NV': 14, 'MEL': 1})\n",
            "Test: 15 ({'NV': 13, 'MEL': 2})\n"
          ]
        }
      ]
    },
