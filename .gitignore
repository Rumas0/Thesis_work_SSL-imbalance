    {
      "cell_type": "markdown",
      "source": [
        "**Creating Labeled Subsets with Controlled Imbalance**"
      ],
      "metadata": {
        "id": "yapDsiv0T6sr"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def create_imbalanced_subset(data, targets, name):\n",
        "    subset = []\n",
        "    for cls, count in targets.items():\n",
        "        cls_data = data[data['label'] == cls]\n",
        "\n",
        "        # Adjust count in csae lack of data\n",
        "        if len(cls_data) < count:\n",
        "            print(f'Warning: only {len(cls_data)} samples available for {cls}, requested {count}')\n",
        "            count = len(cls_data)\n",
        "\n",
        "        # Sampling the data\n",
        "        sampled = cls_data.sample(n=count, random_state=42)\n",
        "        subset.append(sampled)\n",
        "\n",
        "    # Combining everything after loop\n",
        "    result = pd.concat(subset).sample(frac=1, random_state=42).reset_index(drop=True)\n",
        "\n",
        "    print(f'\\n{name} Distribution:')\n",
        "    print(result['label'].value_counts())\n",
        "    print(f'Total: {len(result)}')\n",
        "\n",
        "    print(f'Imbalance ratio: 1:{result[\"label\"].value_counts().max() / result[\"label\"].value_counts().min():.1f}')\n",
        "\n",
        "    return result\n"
      ],
      "metadata": {
        "id": "tIwIx5udzBSV"
      },
      "execution_count": 15,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Subset Generation: Creating 3 Distinct Experimental Scenarios**"
      ],
      "metadata": {
        "id": "BuejVgiD54KZ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "##  Scenario A: Full Thesis Baseline (800 samples, 1:5:10 ratio)\n",
        "\n",
        "exp_a = create_imbalanced_subset(remaining_labeled_candidates, targets={'MEL': 50, 'BKL': 250, 'NV': 500}, name=\"Experiment A (800 images, 1:5:10)\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
        "id": "lezW_EhG6HZu",
        "outputId": "d63448df-bde1-4fbf-9844-dbf99fb22633"
      },
      "execution_count": 16,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
