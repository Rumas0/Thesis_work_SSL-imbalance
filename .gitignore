            "\n",
            "Experiment A (800 images, 1:5:10) Distribution:\n",
            "label\n",
            "NV     500\n",
            "BKL    141\n",
            "MEL     50\n",
            "Name: count, dtype: int64\n",
            "Total: 691\n",
            "Imbalance ratio: 1:10.0\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "## Scenario B: High Imbalance Ablation (500 samples, 1:10 ratio)\n",
        "\n",
        "exp_b = create_imbalanced_subset(remaining_labeled_candidates, targets={'MEL': 45, 'NV': 455}, name=\"experiment B (500 images, 1:10)\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
        "id": "qR0jvvv761uo",
        "outputId": "28dd8fea-7554-4f9d-a4f2-251735688047"
      },
      "execution_count": 17,
      "outputs": [
        {
