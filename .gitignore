        "id": "uDnaPjV2N4jZ"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df['label'] = df[class_columns].idxmax(axis=1)\n",
        "\n",
        "print ('Original Distribution')\n",
